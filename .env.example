# ===== FRONTEND Environment Variables =====
# Copy this file to .env.local for development
# On Netlify: set these in Site Settings > Environment Variables

# For local development:
VITE_API_URL=http://localhost:3000/api

# For production (Netlify) - set this to your Render backend URL:
# VITE_API_URL=https://your-render-app-name.onrender.com/api

# Enable Mock Data (set to 'true' for development without server)
VITE_USE_MOCK_DATA=false

# ===== SERVER Environment Variables =====
# These go in /server/.env (never commit this file!)
# On Render: set these in Environment settings
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/<db>
